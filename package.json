{
	"name": "tinvest-portfolio-terminal",
	"private": true,
	"engines": {
		"node": "25.8.0"
	},
	"scripts": {
		"build": "cd frontend && vite build",
		"dev:frontend": "cd frontend && vite",
		"dev:backend": "cd backend && GOCACHE=$(pwd)/.gocache go run ./cmd/server",
		"dev": "cd frontend && vite",
		"start": "cd frontend && vite preview",
		"typecheck": "cd frontend && tsc",
		"backend:test": "cd backend && GOCACHE=$(pwd)/.gocache go test ./...",
		"check": "cd frontend && ultracite check",
		"fix": "cd frontend && ultracite fix",
		"dohod:load": "node frontend/scripts/bonds-dohod/load.js",
		"dohod:convert": "node frontend/scripts/bonds-dohod/convert.js",
		"dohod:update": "npm run dohod:load && npm run dohod:convert"
	},
	"dependencies": {
		"@mantine/core": "^8.3.16",
		"@mantine/hooks": "^8.3.16",
		"@reatom/core": "alpha",
		"@reatom/react": "alpha",
		"@tinkoff/invest-js-grpc-web": "^1.0.1-RC1",
		"isbot": "^5.1.35",
		"long": "^5.3.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"ts-money": "^0.4.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"date-fns": "^4.1.0",
		"postcss": "^8.5.8",
		"postcss-preset-mantine": "^1.18.0",
		"postcss-simple-vars": "^7.0.1",
		"puppeteer": "^24.38.0",
		"typescript": "^5.9.3",
		"ultracite": "^7.2.4",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-tsconfig-paths": "^6.1.1",
		"xlsx": "^0.18.5"
	}
}
