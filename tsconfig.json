{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "~shared/*": [
        "src/shared/*"
      ],
      "~pages/*": [
        "src/pages/*",
      ]
    }
  }
}
